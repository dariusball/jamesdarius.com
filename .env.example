# ─────────────────────────────────────────────────────────────
# IZUMI — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# ─────────────────────────────────────────────────────────────

# Resend API key — used by /api/waitlist to send/store signups.
# Create a key at https://resend.com/api-keys
# If this is left blank, the waitlist API still returns success and
# logs submissions to the server console (useful for local dev).
RESEND_API_KEY=

# The address waitlist notifications are sent FROM.
# Must be a verified domain/sender in your Resend account.
# Example: "IZUMI Waitlist <waitlist@yourdomain.com>"
WAITLIST_FROM_EMAIL=

# The address that receives a notification for each new signup.
# Example: hello@yourdomain.com
WAITLIST_NOTIFY_EMAIL=
