# ─────────────────────────────────────────────────────────────
# jamesdarius.com — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# Nothing here is required for local development — the contact
# form degrades gracefully and logs submissions to the console.
# ─────────────────────────────────────────────────────────────

# Resend API key — used by /api/contact to email new messages.
# Create a key at https://resend.com/api-keys
# If left blank, the contact form still returns success and logs
# submissions to the server console (useful for local dev).
RESEND_API_KEY=

# The address contact-form notifications are sent FROM.
# Must be a verified domain/sender in your Resend account.
# Example: "James Darius Ball <hello@jamesdarius.com>"
CONTACT_FROM_EMAIL=

# The address that receives each new message.
# Defaults to the `email` in lib/site.ts if left blank.
# Example: hello@jamesdarius.com
CONTACT_NOTIFY_EMAIL=

# ── Future feature flags (off by default) ────────────────────
# Flip to "true" once the corresponding feature is built.
# See lib/extensions.ts for implementation notes.
NEXT_PUBLIC_FEATURE_PAYMENTS=
NEXT_PUBLIC_FEATURE_COMMUNITY=
